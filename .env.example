# ─── Nodemailer (server reads this file — never commit real `.env`) ─────────
# Copy to `.env` in this folder. Run the API with: npm run server (or npm run dev for Vite + API).

# Gmail example: enable 2FA, then create an App Password (Google Account → Security → App passwords).
# Use that value for SMTP_PASS, not your normal Gmail password.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-app-password

# Where inquiries are delivered (defaults to attendx22@gmail.com if unset)
MAIL_TO=attendx22@gmail.com

# Optional: override From header (defaults to "Trainova" <SMTP_USER>)
# MAIL_FROM="Trainova <your.address@gmail.com>"

PORT=3001

# Dev: Vite origin(s) allowed by CORS (comma-separated). Omit to allow all in dev.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ─── Frontend only (optional) ───────────────────────────────────────────────
# If the contact API is on another origin in production, set the base URL (no trailing slash).
# Leave empty when the same host proxies /api to this server.
# VITE_CONTACT_API_URL=https://api.yoursite.com
